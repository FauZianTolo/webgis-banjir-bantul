# ============================================================
# APP CONFIGURATION
# ============================================================
APP_NAME="WebGIS Banjir Bantul"
APP_ENV=production
APP_KEY=                    # ← KOSONGKAN DULU, akan di-generate
APP_DEBUG=false
APP_URL=https://bantara.my.id

# ============================================================
# DATABASE — Akan diisi dengan credential Rumahweb (Fase 5)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=             # ← Nama database di Rumahweb (Fase 3)
DB_USERNAME=             # ← Username database Rumahweb (Fase 3)
DB_PASSWORD=             # ← Password database Rumahweb (Fase 3)

# ============================================================
# CACHE & SESSION
# ============================================================
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ============================================================
# EMAIL — Isi sesuai email aktif (Fase 9)
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=emailkamu@gmail.com
MAIL_PASSWORD=apppassword_gmail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=emailkamu@gmail.com
MAIL_FROM_NAME="WebGIS Banjir Bantul"

# ============================================================
# CLOUDINARY — Untuk upload foto laporan
# ============================================================
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ============================================================
# WHATSAPP NOTIFICATION — Opsional
# ============================================================
WHATSAPP_ENABLED=false
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ADMIN_PHONE=6287834755177
WHATSAPP_USE_TEMPLATE=false
WHATSAPP_TEMPLATE_LANGUAGE=id
